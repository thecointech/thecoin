{
  "extends": "./tsconfig.apps.json",
  "compilerOptions": {
    "plugins": [
      {
        "transform": "@formatjs/ts-transformer",
        "import": "transform",
        "type": "config",
        "overrideIdFn": "[sha512:contenthash:base64:6]",
        "ast": true
      }
    ],
    "noEmit": true,
    "jsx": "react-jsx",
    "tsBuildInfoFile": "./build/.buildinfo",
  },
}
