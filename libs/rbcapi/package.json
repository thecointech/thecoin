{
  "name": "@thecointech/rbcapi",
  "version": "0.6.3",
  "description": "The Coin: A puppeteer-based API for Royal Bank of Canada",
  "type": "module",
  "keywords": [
    "THECoin",
    "RBC",
    "Bank",
    "API",
    "puppeteer"
  ],
  "author": "Stephen Taylor <stephen@thecoin.io>",
  "homepage": "http://thecoin.io",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thecointech/thecoin.git",
    "directory": "libs/rbcapi"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "prepublishOnly": "yarn run -T rimraf ./build/.buildinfo",
    "build": "run -T tsc -b",
    "clean": "rimraf ./build && rimraf ./coverage",
    "test": "run :jest --runInBand --detectOpenHandles --forceExit",
    "test:summary": "jest --coverage > ./coverage/summary.txt"
  },
  "files": [
    "build/**/*"
  ],
  "exports": {
    ".": {
      "development": "./mocked/index.ts",
      "devlive": "./mocked/index.ts",
      "prodtest": "./mocked/index.ts",
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./transactions": {
      "types": "./build/transactions.d.ts",
      "default": "./build/transactions.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "build/*"
      ]
    }
  },
  "dependencies": {
    "@thecointech/bank-interface": "^0.6.3",
    "@thecointech/logging": "^0.6.3",
    "@thecointech/scraper": "^0.6.3",
    "@thecointech/secrets": "^0.6.3",
    "@thecointech/store": "^0.6.3",
    "@thecointech/utilities": "^0.6.3",
    "csvtojson": "^2.0.13",
    "luxon": "3.3.0",
    "promise.any": "^2.0.4"
  },
  "devDependencies": {
    "@thecointech/jestutils": "^0.6.3",
    "@thecointech/types": "^0.6.3",
    "@types/promise.any": "^2.0.0"
  },
  "gitHead": "bea153a75a41c0544d4a11901ccade3bfbb2536e"
}
